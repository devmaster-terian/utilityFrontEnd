            "userConfig": {
                "fn": "buildCollectionsPayload",
                "implHandler": [
                    "var store = Ext.getStore('storeCollection');",
                    "var collectionIds = [];",
                    "",
                    "if (!store) {",
                    "    return {",
                    "        collection_ids: []",
                    "    };",
                    "}",
                    "",
                    "store.each(function (rec) {",
                    "    if (rec.get('selected')) {",
                    "        collectionIds.push(rec.get('id_collection'));",
                    "    }",
                    "});",
                    "",
                    "return {",
                    "    collection_ids: collectionIds",
                    "};"
                ]
            },
            "configAlternates": {
