                                                "fn": "onDataViewConfigChildtap",
                                                "implHandler": [
                                                    "var btn = location.event.getTarget('.action-btn');",
                                                    "var record = location.record;",
                                                    "",
                                                    "if (!record) {",
                                                    "    return;",
                                                    "}",
                                                    "",
                                                    "if (btn) {",
                                                    "    var action = btn.getAttribute('data-action');",
                                                    "    location.event.stopEvent();",
                                                    "",
                                                    "    switch (action) {",
                                                    "        case 'toggle-select':",
                                                    "            record.set('selected', !record.get('selected'));",
                                                    "            break;",
                                                    "",
                                                    "        default:",
                                                    "            console.log('Evento no definido');",
                                                    "    }",
                                                    "",
                                                    "    return;",
                                                    "}",
                                                    "",
                                                    "// Si se toca fuera del botón, también alterna selección",
                                                    "record.set('selected', !record.get('selected'));"
                                                ],
