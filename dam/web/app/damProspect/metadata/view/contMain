                                                "fn": "string",
                                                "implHandler": "code",
                                                "name": "string"
                                            },
                                            "name": "onDataViewAssetsChildtap",
                                            "designerId": "a6a4c140-c266-4560-8796-bc3326a3e0ae"
                                        }
                                    ]
                                },
                                {
                                    "type": "basicfunction",
                                    "reference": {
                                        "name": "items",
                                        "type": "array"
                                    },
                                    "codeClass": null,
                                    "userConfig": {
                                        "designer|params": [
                                            "record"
                                        ],
                                        "fn": "deleteAsset",
                                        "implHandler": [
                                            "var id_prospect = jsTerian.getDataObjSS('UTM_PROSPECT','id_prospect');",
                                            "var id_asset    = record.data.id_asset;",
                                            "",
                                            "var fnSuccess = function(pResponse){",
                                            "    console.log('Success: Prospecto Asignado');",
                                            "",
                                            "    var msg;",
                                            "    try {",
                                            "        msg = Ext.decode(pResponse.responseText);",
                                            "    }",
                                            "    catch(e){",
                                            "        msg = { success:true, message:'Success', data:{} };",
                                            "    }",
                                            "",
                                            "    console.log('msg: ', msg);",
                                            "",
                                            "    // Elige el primero que esta disponible",
                                            "    var data = msg.data || {};",
                                            "",
                                            "    console.log('data:',data);",
                                            "",
                                            "    Ext.getCmp('contMain').prospectDetail(id_prospect);",
                                            "    //Ext.getCmp('contMain').prospectStatus();",
                                            "};",
                                            "",
                                            "var fnFailure = function(pResponse){",
                                            "    console.log('Failure: Prospecto fallo el grado');",
                                            "};",
                                            "",
                                            "",
                                            "var endPoint = 'prospect/'+ id_prospect + '/assets/' + id_asset;",
                                            "var url = jsTerian.getUrl(endPoint);",
                                            "",
                                            "// Informacion a enviar",
                                            "var jsonData = JSON.stringify({",
                                            "    'id_prospect' : id_prospect,",
                                            "    'id_asset'    : id_asset",
                                            "});",
                                            "",
                                            "console.info('jsonData:',jsonData);",
                                            "console.info('url:',url);",
                                            "",
                                            "jsTerian.makeRequest('DELETE',url, jsonData, fnSuccess, fnFailure, true);"
                                        ]
                                    },
                                    "configAlternates": {
                                        "designer|params": "typedarray",
                                        "fn": "string",
                                        "implHandler": "code"
                                    },
                                    "name": "deleteAsset",
                                    "designerId": "1eabf6f6-1db0-4635-9890-76141909f413"
                                }
                            ]
