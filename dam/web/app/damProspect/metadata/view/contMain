                                        {
                                            "type": "basiceventbinding",
                                            "reference": {
                                                "name": "listeners",
                                                "type": "array"
                                            },
                                            "codeClass": null,
                                            "userConfig": {
                                                "fn": "onDataViewAssetsChildtap",
                                                "implHandler": [
                                                    "// 1. Detectar si el toque fue en un botón de acción",
                                                    "// Buscamos la clase '.action-btn' en el elemento tocado o sus padres",
                                                    "var btn = location.event.getTarget('.action-btn');",
                                                    "",
                                                    "if (btn) {",
                                                    "    // 2. Extraer la acción y el registro",
                                                    "    var action = btn.getAttribute('data-action');",
                                                    "    var record = location.record;",
                                                    "",
                                                    "    // Detenemos la propagación para que no seleccione la fila al tocar el botón",
                                                    "    location.event.stopEvent();",
                                                    "",
                                                    "    // 3. Switch Maestro de Acciones",
                                                    "    switch (action) {",
                                                    "        case 'view':",
                                                    "",
                                                    "            var url = jsTerian.makeUrl('asset/download',record.data.id_asset);",
                                                    "            var objConfig = {",
                                                    "                title  : record.data.name};",
                                                    "            jsDam.previewFileFromURL(",
                                                    "                url,",
                                                    "                objConfig",
                                                    "            );",
                                                    "",
                                                    "            break;",
                                                    "",
                                                    "        case 'edit':",
                                                    "            console.warn('Tap: view');",
                                                    "            var form = Ext.getCmp(\"formRecord\");",
                                                    "            form.isCreate = false;",
                                                    "            form.userRecord = record;",
                                                    "            this.showForm();",
                                                    "            break;",
                                                    "",
                                                    "        case 'download':",
                                                    "            console.warn('Tap: download');",
                                                    "            var url = jsTerian.makeUrl('asset/download',record.data.id_asset);",
                                                    "            appLocal.downloadFileFromUrl(",
                                                    "              url + '?download=true',",
                                                    "              {",
                                                    "                  filename: record.data.original_filename",
                                                    "              }",
                                                    "            );",
                                                    "",
                                                    "            break;",
                                                    "",
                                                    "        case 'email':",
                                                    "            console.warn('Tap: email');",
                                                    "            this.sendByEmail(record);",
                                                    "            break;",
                                                    "",
                                                    "        case 'whatsapp':",
                                                    "            console.warn('Tap: whatsapp');",
                                                    "            jsTerian.sendToWhatsApp(record);",
                                                    "            break;",
                                                    "",
                                                    "        case 'attach':",
                                                    "            console.warn('Tap: attach');",
                                                    "            jsTerian.copyLinkToClipboard(record);",
                                                    "            break;",
                                                    "",
                                                    "        case 'delete':",
                                                    "",
                                                    "            var information = '¿Realmente deseas eliminar este registro?</br>' +",
                                                    "                              record.data.original_filename + '</br></br>' +",
                                                    "                              'Esta acción no se puede deshacer.';",
                                                    "",
                                                    "            Ext.Msg.show({",
                                                    "                title: 'Eliminar Registro',",
                                                    "                message: information,",
                                                    "                width: 300, // Opcional",
                                                    "                closable: false,",
                                                    "                icon: Ext.Msg.QUESTION,",
                                                    "                buttons: [",
                                                    "                    {",
                                                    "                        text: 'No',",
                                                    "                        itemId: 'no'",
                                                    "                    },",
                                                    "                    {",
                                                    "                        text: 'Sí, borrar',",
                                                    "                        itemId: 'yes',",
                                                    "                        ui: 'action-decline' // En Modern, esto suele poner el botón en rojo",
                                                    "                    }",
                                                    "                ],",
                                                    "                fn: function (buttonId) {",
                                                    "                    if (buttonId === 'yes') {",
                                                    "                        // Lógica de borrado",
                                                    "",
                                                    "",
                                                    "",
                                                    "                        //var idRole = record.id_role;",
                                                    "                        //appLocal.deleteRole(idRole);",
                                                    "",
                                                    "                        Ext.getCmp('contFiles').deleteAsset(record);",
                                                    "",
                                                    "                        console.log('Registro eliminado');",
                                                    "                        console.log('record:',record);",
                                                    "                    }",
                                                    "                }",
                                                    "            });",
                                                    "            break;",
                                                    "",
                                                    "        default:",
                                                    "            console.log('Evento no definido');",
                                                    "    }",
                                                    "}"
                                                ],
                                                "name": "childtap"
                                            },
