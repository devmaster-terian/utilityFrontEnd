                "implHandler": [
                    "// Función para formatear el tamaño (Bytes a KB, MB, etc.)",
                    "const formatBytes = (bytes, decimals = 2) => {",
                    "    if (!bytes || bytes === 0) return '0 Bytes';",
                    "    const k = 1024;",
                    "    const dm = decimals < 0 ? 0 : decimals;",
                    "    const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];",
                    "    const i = Math.floor(Math.log(bytes) / Math.log(k));",
                    "    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];",
                    "};",
                    "",
                    "// Función para obtener la extensión",
                    "const getExt = (name) => {",
                    "    if (!name) return '';",
                    "    return name.slice(((name.lastIndexOf(\".\") - 1) >>> 0) + 2).toUpperCase();",
                    "};",
                    "",
                    "",
                    "const getFileTypeCategory = (extension) => {",
                    "    // 1. Validar que la extensión exista (que no sea null o indefinida)",
                    "    if (!extension) {",
                    "        return 'ARCHIVO';",
                    "    }",
                    "",
                    "    // 2. Limpiar el texto: minúsculas, sin espacios y sin el punto inicial",
                    "    const ext = extension.toLowerCase().trim().replace('.', '');",
                    "",
                    "    // 3. Definir los grupos (puedes agregar más si lo necesitas)",
                    "    const images = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg', 'bmp', 'tiff'];",
                    "    const videos = ['mp4', 'mov', 'webm', 'avi', 'mkv', 'wmv'];",
                    "    const office = ['doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx'];",
                    "",
                    "    // 4. Evaluar a qué grupo pertenece",
                    "    if (images.includes(ext)) {",
                    "        return 'IMAGEN';",
                    "    }",
                    "",
                    "    if (videos.includes(ext)) {",
                    "        return 'VIDEO';",
                    "    }",
                    "",
                    "    if (ext === 'pdf') {",
                    "        return 'PDF';",
                    "    }",
                    "",
                    "    if (office.includes(ext)) {",
                    "        return 'OFFICE';",
                    "    }",
                    "",
                    "    // 5. Si no coincide con nada de lo anterior, es un archivo genérico",
                    "    return 'ARCHIVO';",
                    "};",
                    "",
                    "var fnSuccess = function(pResponse){",
                    "    console.log('Success: Prospecto Asignado');",
                    "",
                    "    var msg;",
                    "    try {",
                    "        msg = Ext.decode(pResponse.responseText);",
                    "    }",
                    "    catch(e){",
                    "        msg = { success:true, message:'Success', data:{} };",
                    "    }",
                    "",
                    "    console.log('msg: ', msg);",
                    "",
                    "    // Elige el primero que esta disponible",
                    "    var dataProspect = msg.prospect || {};",
                    "",
                    "    console.log('dataProspect:',dataProspect);",
                    "",
                    "    jsTerian.assignElementValue('tfName'      ,dataProspect.name);",
                    "    jsTerian.assignElementValue('tfJobTitle'  ,dataProspect.job_title);",
                    "    jsTerian.assignElementValue('tfCompany'   ,dataProspect.company);",
                    "    jsTerian.assignElementValue('tfMail'      ,dataProspect.email);",
                    "    jsTerian.assignElementValue('tfTelephone' ,dataProspect.telephone);",
                    "    jsTerian.assignElementValue('taNote'      ,dataProspect.notes);",
                    "",
                    "",
                    "    dataProspect.assets.forEach(record => {",
                    "        const filename = record.original_filename; // Extraído de la data",
                    "        const bytes = record.size_bytes;           // Extraído de la data",
                    "",
                    "",
                    "        record.file_extension = getExt(filename);",
                    "        record.file_size      = formatBytes(bytes);",
                    "        record.file_type      = getFileTypeCategory(record.file_extension);",
                    "",
                    "    });",
                    "",
                    "",
                    "    jsTerian.saveDataObjSS('UTM_PROSPECT','num_assets',dataProspect.assets.length);",
                    "    Ext.getStore('storeAsset').setData(dataProspect.assets);",
                    "",
                    "};",
                    "",
                    "var fnFailure = function(pResponse){",
                    "    console.log('Failure: Prospecto fallo el grado');",
                    "};",
                    "",
                    "var endPoint = 'prospect/detail/' + pIdProspect + '?include_users=true&include_assets=true';",
                    "var url = jsTerian.getUrl(endPoint);",
                    "",
                    "// Informacion a enviar",
                    "var jsonData = JSON.stringify({",
                    "    'id_prospect'     : pIdProspect",
                    "});",
                    "",
                    "",
                    "jsTerian.makeRequest('GET',url, jsonData, fnSuccess, fnFailure, true);",
                    ""
                ]
            },
