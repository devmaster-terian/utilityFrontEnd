                                        {
                                            "type": "basiceventbinding",
                                            "reference": {
                                                "name": "listeners",
                                                "type": "array"
                                            },
                                            "codeClass": null,
                                            "userConfig": {
                                                "fn": "onDataViewConfigChildtap",
                                                "implHandler": [
                                                    "// 1. Detectar si el toque fue en un botón de acción",
                                                    "// Buscamos la clase '.action-btn' en el elemento tocado o sus padres",
                                                    "var btn = location.event.getTarget('.action-btn');",
                                                    "",
                                                    "if (btn) {",
                                                    "    // 2. Extraer la acción y el registro",
                                                    "    var action = btn.getAttribute('data-action');",
                                                    "    var record = location.record.data;",
                                                    "",
                                                    "    // Detenemos la propagación para que no seleccione la fila al tocar el botón",
                                                    "    location.event.stopEvent();",
                                                    "",
                                                    "    // 3. Switch Maestro de Acciones",
                                                    "    switch (action) {",
                                                    "        case 'view':",
                                                    "            console.warn('Tap: view');",
                                                    "            var form = Ext.getCmp(\"formConfig\");",
                                                    "            form.isCreate = false;",
                                                    "            form.configRecord = record;",
                                                    "            this.showForm();",
                                                    "            break;",
                                                    "",
                                                    "        case 'edit':",
                                                    "            console.warn('Tap: view');",
                                                    "            var form = Ext.getCmp(\"formConfig\");",
                                                    "            form.isCreate = false;",
                                                    "            form.configRecord = record;",
                                                    "            this.showForm();",
                                                    "            break;",
                                                    "",
                                                    "        case 'download':",
                                                    "            console.warn('Tap: download');",
                                                    "            this.downloadFile(record);",
                                                    "            break;",
                                                    "",
                                                    "        case 'activate':",
                                                    "            Ext.Msg.show({",
                                                    "                    title: 'Activar  Registro',",
                                                    "                    message: '¿Deseas activar  este registro?',",
                                                    "                    width: 300,",
                                                    "                    closable: false,",
                                                    "                    icon: Ext.Msg.QUESTION,",
                                                    "                    buttons: [",
                                                    "                        { text: 'No', itemId: 'no' },",
                                                    "                        { text: 'Sí, activar', itemId: 'yes', ui: 'action-decline' }",
                                                    "                    ],",
                                                    "                    fn: function (buttonId) {",
                                                    "                        if (buttonId === 'yes') {",
                                                    "",
                                                    "                            var payload = {",
                                                    "                                id_configuration : record.id_configuration,",
                                                    "                                is_active        : true",
                                                    "                            };",
                                                    "",
                                                    "                            appLocal.saveConfig(payload, false);",
                                                    "",
                                                    "                            console.log('Registro desactivado');",
                                                    "                        }",
                                                    "                    }",
                                                    "                });",
                                                    "                break;",
                                                    "",
                                                    "        case 'deactivate':",
                                                    "            Ext.Msg.show({",
                                                    "                    title: 'Desactivar Registro',",
                                                    "                    message: '¿Deseas desactivar este registro?',",
                                                    "                    width: 300,",
                                                    "                    closable: false,",
                                                    "                    icon: Ext.Msg.QUESTION,",
                                                    "                    buttons: [",
                                                    "                        { text: 'No', itemId: 'no' },",
                                                    "                        { text: 'Sí, desactivar', itemId: 'yes', ui: 'action-decline' }",
                                                    "                    ],",
                                                    "                    fn: function (buttonId) {",
                                                    "                        if (buttonId === 'yes') {",
                                                    "",
                                                    "                            var payload = {",
                                                    "                                id_configuration : record.id_configuration,",
                                                    "                                is_active        : false",
                                                    "                            };",
                                                    "",
                                                    "                            appLocal.saveConfig(payload, false);",
                                                    "",
                                                    "                            console.log('Registro desactivado');",
                                                    "                        }",
                                                    "                    }",
                                                    "                });",
                                                    "                break;",
                                                    "",
                                                    "        case 'restore':",
                                                    "            Ext.Msg.show({",
                                                    "                title: 'Restaurar Registro',",
                                                    "                message: '¿Realmente deseas restaurar este registro? Esta acción podría provocar algún error.',",
                                                    "                width: 300, // Opcional",
                                                    "                closable: false,",
                                                    "                icon: Ext.Msg.QUESTION,",
                                                    "                buttons: [",
                                                    "                    {",
                                                    "                        text: 'No',",
                                                    "                        itemId: 'no'",
                                                    "                    },",
                                                    "                    {",
                                                    "                        text: 'Sí, restaurar',",
                                                    "                        itemId: 'yes',",
                                                    "                        ui: 'action-decline'",
                                                    "                    }",
                                                    "                ],",
                                                    "                fn: function (buttonId) {",
                                                    "                    if (buttonId === 'yes') {",
                                                    "",
                                                    "                        var idConfig = record.id_configuration;",
                                                    "                        appLocal.restoreConfig(idConfig);",
                                                    "",
                                                    "                        console.log('Registro restaurado');",
                                                    "                    }",
                                                    "                }",
                                                    "            });",
                                                    "            break;",
                                                    "",
                                                    "        case 'delete':",
                                                    "            Ext.Msg.show({",
                                                    "                title: 'Eliminar Registro',",
                                                    "                message: '¿Realmente deseas eliminar este registro? Esta acción no se puede deshacer.',",
                                                    "                width: 300,",
                                                    "                closable: false,",
                                                    "                icon: Ext.Msg.QUESTION,",
                                                    "                buttons: [",
                                                    "                    {",
                                                    "                        text: 'No',",
                                                    "                        itemId: 'no'",
                                                    "                    },",
                                                    "                    {",
                                                    "                        text: 'Sí, borrar',",
                                                    "                        itemId: 'yes',",
                                                    "                        ui: 'action-decline'",
                                                    "                    }",
                                                    "                ],",
                                                    "                fn: function (buttonId) {",
                                                    "                    if (buttonId === 'yes') {",
                                                    "",
                                                    "                        var idConfig = record.id_configuration;",
                                                    "                        appLocal.deleteConfig(idConfig);",
                                                    "",
                                                    "                        console.log('Registro eliminado');",
                                                    "                    }",
                                                    "                }",
                                                    "            });",
                                                    "            break;",
                                                    "",
                                                    "        default:",
                                                    "            console.log('Evento no definido');",
                                                    "    }",
                                                    "}"
                                                ],
                                                "name": "childtap"
                                            },
                                            "configAlternates": {
                                                "fn": "string",
                                                "implHandler": "code",
                                                "name": "string"
                                            },
                                            "name": "onDataViewConfigChildtap",
                                            "designerId": "4cf44224-a443-4e25-98a3-debcd3df726a"
                                        }
                                    ]
                                }
                            ]
