                                                    "        <div class=\"sub-text\">",
                                                    "            <tpl if=\"values.node_type === 'collection'\">",
                                                    "                <span class=\"role-badge\">",
                                                    "                    <i class=\"x-fa fas fa-plus-circle\"></i>",
                                                    "                    Puede contener: Colección, Recurso",
                                                    "                </span>",
                                                    "            </tpl>",
                                                    "",
                                                    "            <tpl if=\"values.node_type === 'resource'\">",
                                                    "                <span class=\"role-badge\">",
                                                    "                    <i class=\"x-fa fas fa-plus-circle\"></i>",
                                                    "                    Puede contener: Pestañas",
