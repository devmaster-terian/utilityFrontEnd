        {
            "type": "basicfunction",
            "reference": {
                "name": "items",
                "type": "array"
            },
            "codeClass": null,
            "userConfig": {
                "designer|params": [
                    "form",
                    "data"
                ],
                "fn": "fillNodeForm",
                "implHandler": [
                    "if (!data) return;",
                    "",
                    "// Limpiar",
                    "var trim = function(v){",
                    "    return (v === null || v === undefined) ? '' : String(v).trim();",
                    "};",
                    "",
                    "// Tipo y estado",
                    "var nodeType = trim(data.node_type); // 'collection' | 'resource' | 'tab'",
                    "",
                    "// Muestra el tipo en el combo",
                    "try { jsTerian.assignElementValue('cboNodeType', nodeType); } catch(e){}",
                    "",
                    "// Activo/inactivo",
                    "if (data.is_active !== undefined) {",
                    "    try { jsTerian.assignElementValue('cboAdmIsActive', !!data.is_active); } catch(e){}",
                    "    try { jsTerian.assignElementValue('cboIsActive', !!data.is_active); } catch(e){}",
                    "}",
                    "",
                    "// Padre",
                    "if (data.parent_id || data.parentId) {",
                    "    try { jsTerian.assignElementValue('ftParentId', trim(data.parent_id || data.parentId)); } catch(e){}",
                    "}",
                    "",
                    "// Collection",
                    "if (nodeType === 'collection') {",
                    "    // Algunos backends usan name/description, otros name/short_description",
                    "    jsTerian.assignElementValue('ftColName', trim(data.name));",
                    "    jsTerian.assignElementValue('ftColDesc', trim(data.description) || trim(data.short_description) || '');",
                    "    return;",
                    "}",
                    "",
                    "// Rresource",
                    "if (nodeType === 'resource') {",
                    "    // Puede venir como code/description o code/name dependiendo tu API",
                    "    jsTerian.assignElementValue('ftResCode', trim(data.code));",
                    "    jsTerian.assignElementValue('ftResDesc', trim(data.description) || trim(data.name) || '');",
                    "    return;",
                    "}",
                    "",
                    "// Tab",
                    "if (nodeType === 'tab') {",
                    "    jsTerian.assignElementValue('ftTabName', trim(data.name));",
                    "    jsTerian.assignElementValue('ftTabCode', trim(data.tab_code));",
                    "    jsTerian.assignElementValue('ftTabShortDesc', trim(data.short_description));",
                    "",
                    "    // sort_order default 1",
                    "    var sort = data.sort_order;",
                    "    if (sort === null || sort === undefined || sort === '') sort = 1;",
                    "    jsTerian.assignElementValue('ftTabSortOrder', sort);",
                    "",
                    "    // asset_type_code (combo)",
                    "    jsTerian.assignElementValue('cboTabAssetType', trim(data.asset_type_code));",
                    "    return;",
                    "}",
                    "",
                    "// debug",
                    "//console.warn('[fillNodeForm] node_type desconocido:', nodeType, data);"
                ]
            },
